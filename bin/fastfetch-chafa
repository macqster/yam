#!/bin/zsh

set -euo pipefail

logo_file="$(mktemp /tmp/fastfetch-chafa-logo.XXXXXX)"
trap 'rm -f "$logo_file"' EXIT

LOGO_MODE=1 MODE=still WIDTH=36 HEIGHT=19 "$HOME/.local/share/fastfetch-chafa/chafa_lab.sh" \
  | perl -pe 's/\e\[\?25[lh]//g' \
  > "$logo_file"

fastfetch \
  -c "$HOME/.config/fastfetch/config.jsonc" \
  --file-raw "$logo_file"
