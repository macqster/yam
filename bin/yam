#!/bin/zsh

set -euo pipefail
unsetopt xtrace 2>/dev/null || true
setopt typesetsilent 2>/dev/null || true

REPO_ROOT="${YAM_REPO:-$HOME/_git/yam}"
SCENE_ACTION=""
SCENE_SET=""
FORWARDED_ARGS=()
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

export PYTHONPATH="$REPO_ROOT${PYTHONPATH:+:$PYTHONPATH}"

show_help() {
  cat <<'EOF'
usage: yam [ARGS...]

Launch YAM.

Options:
  --scene-config ACT   Show, edit, or reset the repo-tracked scene config.
  --scene-set KEY=VAL  Update one supported scene config key.
  -h, --help          Show this help text.

Examples:
  yam
  yam --scene-config show
  yam --scene-config edit
  yam --scene-config reset
  yam --scene-set clock_font_name=Fender
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      show_help
      exit 0
      ;;
    --scene-config)
      if [[ $# -lt 2 ]]; then
        echo "yam: --scene-config requires show, edit, or reset" >&2
        exit 1
      fi
      SCENE_ACTION="$2"
      shift 2
      ;;
    --scene-config=*)
      SCENE_ACTION="${1#*=}"
      shift
      ;;
    --scene-set)
      if [[ $# -lt 2 ]]; then
        echo "yam: --scene-set requires KEY=VALUE" >&2
        exit 1
      fi
      SCENE_SET="$2"
      shift 2
      ;;
    --scene-set=*)
      SCENE_SET="${1#*=}"
      shift
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        FORWARDED_ARGS+=("$1")
        shift
      done
      ;;
    *)
      FORWARDED_ARGS+=("$1")
      shift
      ;;
  esac
done

SCENE_CONFIG_PATH="$REPO_ROOT/scene_config.json"
if [[ -n "$SCENE_SET" ]]; then
  python3 - "$SCENE_CONFIG_PATH" "$SCENE_SET" <<'PY'
from pathlib import Path
import sys

from config import update_scene_config_value

path = Path(sys.argv[1])
pair = sys.argv[2]
if "=" not in pair:
    raise SystemExit("yam: --scene-set requires KEY=VALUE")
key, value = pair.split("=", 1)
update_scene_config_value(path, key, value)
PY
  exit 0
fi

if [[ -n "$SCENE_ACTION" ]]; then
  case "$SCENE_ACTION" in
    show)
      cat "$SCENE_CONFIG_PATH"
      exit 0
      ;;
    edit)
      editor="${EDITOR:-${VISUAL:-nano}}"
      exec "$editor" "$SCENE_CONFIG_PATH"
      ;;
    reset)
      python3 - "$SCENE_CONFIG_PATH" <<'PY'
from pathlib import Path
import sys

from config import SceneConfig, dump_scene_config

dump_scene_config(
    SceneConfig(
        clock_font_name="Fender",
        day_format="%A, %d %B",
        clock_format="%H:%M",
        theme_name="btas_dark_deco",
    ),
    Path(sys.argv[1]),
)
PY
      exit 0
      ;;
    *)
      echo "yam: unknown scene-config action '$SCENE_ACTION' (expected show, edit, or reset)" >&2
      exit 1
      ;;
  esac
fi

cd "$REPO_ROOT"
exec go run ./cmd/yamv2 "${FORWARDED_ARGS[@]}"
