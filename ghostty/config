# yam Ghostty baseline
#
# Source of truth:
#   ~/_git/yam/ghostty/config
#
# This file is installed by symlink into:
#   ~/Library/Application Support/com.mitchellh.ghostty/config.ghostty
#
# Keep this conservative. Only include settings that are stable and clearly
# useful for the current macOS + Ghostty + yam visualizer workflow.

font-family = "JetBrainsMono Nerd Font"
font-feature = liga=1
font-size = 12
theme = yam-dark
macos-option-as-alt = true

background-opacity = 0.95
window-padding-x = 14
window-padding-y = 12
window-padding-balance = true
 
# Default window size (columns x rows)
window-width = 124
window-height = 32
window-save-state = never

background-blur = 6
macos-titlebar-style = transparent
alpha-blending = linear-corrected

cursor-style = block
cursor-style-blink = false


shell-integration = zsh

confirm-close-surface = false

copy-on-select = clipboard
quit-after-last-window-closed = false

# NOTE:
# `initial-window` is not a valid Ghostty configuration option and will cause errors if used.
# Ghostty manages initial window behavior internally; do not add this key here.
# `cursor-thickness` is also not a valid Ghostty configuration key.
# If cursor width tuning is needed in supported Ghostty versions, use `adjust-cursor-thickness` instead.
