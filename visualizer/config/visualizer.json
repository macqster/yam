{
  "_about": "YAM visualizer configuration. Safe rule for editing: change values, keep key names the same unless you also update the Python code. Keys starting with '_' are human-readable notes and are ignored by the current code.",

  "_editing_guide": {
    "_about": "Quick orientation for new users.",
    "asset_paths": "Point to source files used by the visualizer, such as the hero GIF, fallback image, and hero mask files.",
    "timing": "Controls how fast the screen redraws, how often the hero frame advances, and how quickly ivy updates.",
    "layout": "Controls where the hero and info panel sit on the screen, and how much space they reserve around themselves.",
    "ivy": "Controls growth behavior, direction bias, collision handling, and ornament generation.",
    "panel": "Controls the small info panel shown in the scene.",
    "warning": "If something looks wrong, first check file paths, then mask settings, then layout offsets."
  },

  "chafa": {
    "_about": "Hero image rendering settings. This group controls how the source GIF is converted into ANSI/text frames.",
