    "frame_count": 64,
    "width": 72,
    "height": 36,
    "align": "left,top",
    "symbols": "braille",
    "fill": "none",
    "colors": "full",
    "color_space": "din99d",
    "color_extractor": "median",
    "fg_only": true,
    "bg": "100100",
    "threshold": 0.5,
    "dither": "diffusion",
